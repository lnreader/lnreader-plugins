import { createRequestManager } from '@libs/RequestManager';
import * as cheerio from 'cheerio';
import { Source } from '@lnreader/plugin-core';

const BASE_URL = 'https://novelhi.com';

export default class NovelHi extends Source {
  constructor() {
    super({
      id: 'novelhi',
      name: 'NovelHi',
      baseUrl: BASE_URL,
      lang: 'en',
    });

    this.requestManager = createRequestManager({
      requestsPerSecond: 2,
    });
  }

  async getPopularNovels(page: number) {
    const res = await this.requestManager.schedule({
      url: `${BASE_URL}/popular?page=${page}`,
      method: 'GET',
    });

    const $ = cheerio.load(res.data);
    const novels = [];

    $('.book-item').each((_, el) => {
      novels.push({
        id: $(el).find('a').attr('href'),
        name: $(el).find('.book-name').text().trim(),
        image: $(el).find('img').attr('src'),
      });
    });

    return novels;
  }

  async searchNovels(query: string) {
    const res = await this.requestManager.schedule({
      url: `${BASE_URL}/search?keyword=${encodeURIComponent(query)}`,
      method: 'GET',
    });

    const $ = cheerio.load(res.data);
    const novels = [];

    $('.book-item').each((_, el) => {
      novels.push({
        id: $(el).find('a').attr('href'),
        name: $(el).find('.book-name').text().trim(),
        image: $(el).find('img').attr('src'),
      });
    });

    return novels;
  }

  async getNovelDetails(novelId: string) {
    const res = await this.requestManager.schedule({
      url: `${BASE_URL}${novelId}`,
      method: 'GET',
    });

    const $ = cheerio.load(res.data);

    const chapters = [];

    $('.chapter-list a').each((_, el) => {
      chapters.push({
        id: $(el).attr('href'),
        name: $(el).text().trim(),
      });
    });

    return {
      id: novelId,
      name: $('h1').text().trim(),
      image: $('.book-img img').attr('src'),
      author: $('.book-info p').first().text().replace('Author:', '').trim(),
      chapters,
    };
  }

  async getChapterDetails(chapterId: string) {
    const res = await this.requestManager.schedule({
      url: `${BASE_URL}${chapterId}`,
      method: 'GET',
    });

    const $ = cheerio.load(res.data);

    return {
      id: chapterId,
      content: $('.chapter-content').html(),
    };
  }
}
